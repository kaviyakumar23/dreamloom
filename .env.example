# Google AI / Vertex AI
GOOGLE_API_KEY=your-google-ai-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# GCS bucket for media assets
GCS_BUCKET_NAME=dreamloom-media-assets

# Models — two-model architecture
# Scene model: generates interleaved text+image (response_modalities=["TEXT","IMAGE"])
# Options: gemini-2.0-flash, gemini-2.5-flash-image, gemini-3-pro-image-preview
SCENE_MODEL=gemini-2.5-flash-image

# Conversation model: Live API for real-time voice (used via ADK run_live)
# Must support bidiGenerateContent. Options: gemini-2.5-flash-native-audio-latest
CONVERSATION_MODEL=gemini-2.5-flash-native-audio-latest

# Server config
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (set in frontend/.env)
# VITE_WS_URL=ws://localhost:8000/ws
